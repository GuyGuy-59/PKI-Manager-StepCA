# Secrets and CA key material — NEVER commit these.
secrets/*
!secrets/.gitkeep
volumes/stepca/secrets/*
!volumes/stepca/secrets/.gitkeep
volumes/stepca/db/
volumes/nginx/intermediate_ca.crt

# PostgreSQL data volume (generated by the pki-db container).
volumes/db/*
!volumes/db/.gitkeep

# Offline root vault — root private key + password. Move to cold storage.
root-ca-offline/

# Generated CA (keys + config). Regenerate with init-ca.sh.
volumes/stepca/certs/
volumes/stepca/config/ca.json
volumes/stepca/config/templates/certs/x509/leaf.tpl

# Python
__pycache__/
*.pyc

# Local domain configuration
.env