{{- /*
  certType is carried in via a private, non-critical CSR extension (OID
  1.3.6.1.4.1.99999.1.1 — a made-up private-use arc; this marker is never
  validated by anyone but our own leaf.tpl/services.py pair and never copied
  into the issued certificate, so global uniqueness doesn't matter here).
  x509util.Extension's .ID has no .String method (it's a plain []int), so
  match it via its %v formatting instead ("[1 3 6 1 4 1 99999 1 1]").
*/ -}}
{{- $certType := "server" }}
{{- range .Insecure.CR.Extensions }}
{{- if eq (printf "%v" .ID) "[1 3 6 1 4 1 99999 1 1]" }}
{{- $certType = (printf "%s" .Value) }}
{{- end }}
{{- end }}
{
        "subject": {
                "commonName": {{ toJson .Subject.CommonName }},
                "organization": "Smallstep CA UI"
        },
{{- if .SANs }}
        "sans": {{ toJson .SANs }},
{{- end }}
{{- if eq $certType "client" }}
        "keyUsage": ["digitalSignature"],
        "extKeyUsage": ["clientAuth"],
{{- else }}
{{- if typeIs "*rsa.PublicKey" .Insecure.CR.PublicKey }}
        "keyUsage": ["keyEncipherment", "digitalSignature"],
{{- else }}
        "keyUsage": ["digitalSignature"],
{{- end }}
        "extKeyUsage": ["serverAuth"],
{{- end }}
        "issuingCertificateURL": "http://${CA_DNS}/intermediate_ca.crt",
        "crlDistributionPoints": "http://${CA_DNS}/intermediate_ca.crl"
}
